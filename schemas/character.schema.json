{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Character",
  "type": "object",
  "required": ["id", "name", "role"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "role": { "type": "string" },
    "personality": {
      "type": "array",
      "items": { "type": "string" }
    },
    "goals": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
